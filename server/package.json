{
  "name": "mempalace-triage-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "sync:once": "bun src/sync/poller.ts --once",
    "triage": "bun src/triage/cli.ts"
  },
  "dependencies": {
    "elysia": "^1.1.25",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/static": "^1.1.1",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
